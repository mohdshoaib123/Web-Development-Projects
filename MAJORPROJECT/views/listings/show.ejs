<% layout("/Layouts/boilerplate") -%>

<head> -->
  <!-- Bootstrap CSS -->
   <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <style>
    body {
      background-color: #ffe4ec; /* light pink */
    }
    .details-box {
      background: #fff;
      padding: 25px;
      border-radius: 10px;
      border-top: 5px solid hotpink;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }
    h3 {
      color: hotpink;
      font-weight: bold;
    }
    .btn-pink {
      background-color: hotpink;
      color: white;
      font-weight: 600;
    }
    .btn-pink:hover {
      background-color: #ff1493;
      color: #fff;
    }
    .btn-delete {
      background-color: #ff4c75;
      color: white;
      font-weight: 600;
    }
    .btn-delete:hover {
      background-color: #e60055;
    }
  </style>
</head>

<body>
  <div class="container mt-5">
    <div class="details-box col-md-6 mx-auto">

      <h3>Listing Details</h3>

      <ul class="list-group mb-4">
        <li class="list-group-item"><strong>Title:</strong> <%= data.title %></li>
        <li class="list-group-item"><strong>Description:</strong> <%= data.description %></li>
        <li class="list-group-item">
          <strong>Price:</strong> ₹<%= data.price.toLocaleString("en-IN") %>
        </li>
        <li class="list-group-item"><strong>Location:</strong> <%= data.location %></li>
        <li class="list-group-item"><strong>Country:</strong> <%= data.country %></li>
      </ul>

      <div class="d-flex gap-3">
        <a href="/listings/<%= data._id %>/edit" class="btn btn-pink flex-fill">
          Edit Listing
        </a>

        <form method="post" action="/listings/<%= data._id %>?_method=delete" class="flex-fill">
          <button class="btn btn-delete w-100">
            Delete Listing
          </button>
        </form>
      </div>

    </div>
  </div>
</body>
