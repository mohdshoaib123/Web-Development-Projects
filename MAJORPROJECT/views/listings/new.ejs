<% layout("/Layouts/boilerplate") -%>

<head>
  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <style>
    body {
      background-color: #ffe4ec; /* light pink */
    }
    .form-container {
      background: #fff;
      padding: 30px;
      border-radius: 10px;
      border-top: 5px solid hotpink;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    h3 {
      color: hotpink;
      font-weight: bold;
    }
    .btn-pink {
      background-color: hotpink;
      color: white;
      font-weight: bold;
    }
    .btn-pink:hover {
      background-color: #ff1493;
    }
  </style>
</head>

<body>
  <div class="container mt-5">
    <div class="form-container col-md-6 mx-auto">

      <h3>Add New Listing</h3>

      <form method="post" action="/listings">

        <div class="mb-3">
          <label class="form-label">Title</label>
          <input type="text" class="form-control" name="title" placeholder="enter title">
        </div>

        <div class="mb-3">
          <label class="form-label">Description</label>
          <input type="text" class="form-control" name="description" placeholder="enter description">
        </div>

        <div class="mb-3">
          <label class="form-label">Price</label>
          <input type="number" class="form-control" name="price" placeholder="enter price">
        </div>

        <div class="mb-3">
          <label class="form-label">Location</label>
          <input type="text" class="form-control" name="location" placeholder="enter location">
        </div>

        <div class="mb-3">
          <label class="form-label">Country</label>
          <input type="text" class="form-control" name="country" placeholder="enter country">
        </div>

        <div class="mb-3">
          <label class="form-label">Image URL</label>
          <input type="text" class="form-control" name="image" placeholder="image url/link">
        </div>

        <button class="btn btn-pink w-100">Add</button>

      </form>

    </div>
  </div>
</body>
