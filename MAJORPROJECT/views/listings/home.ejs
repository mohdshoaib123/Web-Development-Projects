<% layout("/Layouts/boilerplate") -%>

<head>
  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <style>
    body {
      background-color: #ffe4ec; /* light pink */
    }

    .hero-box {
      background: #fff;
      padding: 40px;
      border-radius: 12px;
      text-align: center;
      box-shadow: 0 0 12px rgba(0,0,0,0.1);
      border-top: 5px solid hotpink;
    }

    h1 {
      color: hotpink;
      font-weight: 700;
    }

    .btn-pink {
      background-color: hotpink;
      color: white;
      font-weight: bold;
    }

    .btn-pink:hover {
      background-color: #ff1493;
    }
  </style>
</head>

<body>
  <div class="container mt-5">
    <div class="hero-box mx-auto col-md-8">
      
      <h1>Welcome to Listings App</h1>
      <p class="mt-3">
        Easily create, edit, and manage your listings in a beautiful UI.
      </p>

      <a href="/listing" class="btn btn-pink px-4 mt-3">
        View All Listings
      </a>

    </div>
  </div>
</body>
